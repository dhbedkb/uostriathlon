<section id="{{ include.section_id }}" class="section section-embed apple-panel" data-section-type="embed">
  <div class="container">
    {% include section-heading.html
      eyebrow=include.section.eyebrow
      title=include.section.title
      subtitle=include.section.subtitle
      alignment=include.section.alignment
    %}

    {% if include.section.embeds %}
      {% if include.section.layout == "three" %}
        {% assign facebook_embed = include.section.embeds | first %}

        <div class="embed-grid embed-grid-three embed-grid-balanced">
          <article class="embed-shell live-widget-boundary embed-{{ facebook_embed.provider | default: 'generic' }}">
            <header class="embed-card-heading">
              {% if facebook_embed.provider %}
                <p class="card-label">{{ facebook_embed.provider }}</p>
              {% endif %}

              {% if facebook_embed.title %}
                <h3>{{ facebook_embed.title }}</h3>
              {% endif %}

              {% if facebook_embed.description %}
                <p>{{ facebook_embed.description }}</p>
              {% endif %}
            </header>

            {% if facebook_embed.embed_html %}
              <div class="embed-frame">
                {{ facebook_embed.embed_html }}
              </div>
            {% endif %}

            {% if facebook_embed.url %}
              <div class="embed-mobile-cta">
                {{ facebook_embed.url }}
                  {{ facebook_embed.button_label | default: "Open Facebook" }}
                </a>
              </div>
            {% endif %}
          </article>

          <div class="embed-stack">
            {% for embed in include.section.embeds offset:1 %}
              <article class="embed-shell live-widget-boundary embed-{{ embed.provider | default: 'generic' }}">
                <header class="embed-card-heading">
                  {% if embed.provider %}
                    <p class="card-label">{{ embed.provider }}</p>
                  {% endif %}

                  {% if embed.title %}
                    <h3>{{ embed.title }}</h3>
                  {% endif %}

                  {% if embed.description %}
                    <p>{{ embed.description }}</p>
                  {% endif %}
                </header>

                {% if embed.embed_html %}
                  <div class="embed-frame">
                    {{ embed.embed_html }}
                  </div>
                {% elsif embed.url %}
                  <div class="embed-placeholder">
                    {{ embed.url }}
                      {{ embed.button_label | default: "Open" }}
                    </a>
                  </div>
                {% else %}
                  <div class="embed-placeholder">
                    <p>Embed not configured yet.</p>
                  </div>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </div>
            {% for embed in include.section.embeds offset:1 %}
              <article class="embed-shell live-widget-boundary embed-{{ embed.provider | default: 'generic' }}">
                <header class="embed-card-heading">
                  {% if embed.provider %}
                    <p class="card-label">{{ embed.provider }}</p>
                  {% endif %}

                  {% if embed.title %}
                    <h3>{{ embed.title }}</h3>
                  {% endif %}

                  {% if embed.description %}
                    <p>{{ embed.description }}</p>
                  {% endif %}
                </header>

                {% if embed.embed_html %}
                  <div class="embed-frame">
                    {{ embed.embed_html }}
                  </div>
                {% elsif embed.url %}
                  <div class="embed-placeholder">
                    {{ embed.url }}
                      {{ embed.button_label | default: "Open" }}
                    </a>
                  </div>
                {% else %}
                  <div class="embed-placeholder">
                    <p>Embed not configured yet.</p>
                  </div>
                {% endif %}
              </article>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="embed-grid embed-grid-{{ include.section.layout | default: 'two' }}">
          {% for embed in include.section.embeds %}
            <article class="embed-shell live-widget-boundary embed-{{ embed.provider | default: 'generic' }}">
              <header class="embed-card-heading">
                {% if embed.provider %}
                  <p class="card-label">{{ embed.provider }}</p>
                {% endif %}

                {% if embed.title %}
                  <h3>{{ embed.title }}</h3>
                {% endif %}

                {% if embed.description %}
                  <p>{{ embed.description }}</p>
                {% endif %}
              </header>

              {% if embed.embed_html %}
                <div class="embed-frame">
                  {{ embed.embed_html }}
                </div>
              {% elsif embed.url %}
                <div class="embed-placeholder">
                  {{ embed.url }}
                    {{ embed.button_label | default: "Open" }}
                  </a>
                </div>
              {% else %}
                <div class="embed-placeholder">
                  <p>Embed not configured yet.</p>
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="embed-shell live-widget-boundary embed-{{ include.section.provider | default: 'generic' }}">
        {% if include.section.embed_html %}
          <div class="embed-frame">
            {{ include.section.embed_html }}
          </div>
        {% else %}
          <div class="embed-placeholder">
            <p>Embed not configured yet.</p>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>
